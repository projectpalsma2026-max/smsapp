{
  "expo": {
    "name": "SMS Gateway",
    "slug": "sms-gateway",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.healthfirst.smsgateway",
      "permissions": [
        "RECEIVE_SMS",
        "READ_SMS",
        "INTERNET",
        "FOREGROUND_SERVICE",
        "WAKE_LOCK",
        "ACCESS_NETWORK_STATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "buildToolsVersion": "34.0.0"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4e4442b7-b0bf-4fc8-9dbc-f8129598d3ba"
      }
    }
  }
}